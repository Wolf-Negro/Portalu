# ── Base de datos (PostgreSQL / Neon) ─────────────────────────────────────────
DATABASE_URL=

# ── Auth.js (NextAuth v5) ──────────────────────────────────────────────────────
AUTH_SECRET=

# ── OpenAI (ALU.IA) ────────────────────────────────────────────────────────────
# Opcional: también se puede configurar desde el panel de admin (SystemConfig).
# Si no se define ninguna de las dos, ALU.IA responde en modo demo.
OPENAI_API_KEY=

# ── Meta Ads (Campañas / Dashboard) ────────────────────────────────────────────
# Fallback global. Cada empresa puede tener sus propias credenciales en
# ConfiguracionMeta/MetaSettings (ver lib/meta-credentials.ts).
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── Bot de WhatsApp (Baileys) ──────────────────────────────────────────────────
# Modelo y proveedor de IA usados por el bot conversacional.
OPENROUTER_API_KEY=
AI_MODEL=
# URL pública del sitio (usada por el bot para construir links/CAPI). Default: http://localhost:3000
SITE_URL=
# Puerto del WebSocket server del bot. Default: 3001
WS_PORT=3001

# ── Frontend: conexión al WebSocket del bot ───────────────────────────────────
# Desarrollo local (sin proxy): conexión directa.
NEXT_PUBLIC_WS_HOST=localhost
NEXT_PUBLIC_WS_PORT=3001
# Producción (detrás de nginx): URL completa proxied a localhost:3001, sin
# exponer el puerto directo. Si se define, tiene prioridad sobre HOST/PORT.
# Ejemplo: NEXT_PUBLIC_WS_URL=wss://portalu.pe/ws
NEXT_PUBLIC_WS_URL=
